{
  "manifest_version": 3,
  "name": "AI Form Autofill",
  "version": "1.0",
  "description": "Autofill government forms using Gemini AI extraction.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://nexitsolution.bd/*"
  ],
  "options_page": "options.html",
  "side_panel": {
    "default_path": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.bdris.gov.bd/*",
        "*://*.teletalk.com.bd/*",
        "*://*.indianvisa-bangladesh.nic.in/*",
        "*://pcc.police.gov.bd/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}