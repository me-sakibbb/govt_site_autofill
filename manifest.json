{
  "manifest_version": 3,
  "name": "Autofill Genius AI",
  "version": "1.0",
  "description": "Supercharge your form filling with advanced AI data extraction. Effortlessly handle complex government applications and data entry with one-click accuracy.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://nexitsolution.bd/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "*://bdris.gov.bd/*",
    "*://*.bdris.gov.bd/*",
    "*://teletalk.com.bd/*",
    "*://*.teletalk.com.bd/*",
    "*://indianvisa-bangladesh.nic.in/*",
    "*://*.indianvisa-bangladesh.nic.in/*",
    "*://pcc.police.gov.bd/*",
    "*://*.pcc.police.gov.bd/*"
  ],
  "options_page": "options.html",
  "side_panel": {
    "default_path": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://bdris.gov.bd/*",
        "*://*.bdris.gov.bd/*",
        "*://teletalk.com.bd/*",
        "*://*.teletalk.com.bd/*",
        "*://indianvisa-bangladesh.nic.in/*",
        "*://*.indianvisa-bangladesh.nic.in/*",
        "*://pcc.police.gov.bd/*",
        "*://*.pcc.police.gov.bd/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.min.mjs", "pdf.worker.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}